@model IEnumerable<KR5.Models.Material>
@{ ViewData["Title"] = "Материалы"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Материалы на складе</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">+ Добавить</button>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr><th>Название</th><th>Количество</th><th>Ед. изм.</th><th>Мин. запас</th><th>Действия</th></tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                var isLow = m.Quantity <= m.MinimalStock;
                <tr>
                    <td>@m.Name</td>
                    <td>
                        <span class="fw-bold @(isLow ? "text-danger" : "text-success")">
                            @m.Quantity
                        </span>
                        @if (isLow)
                        {
                            <span class="badge bg-danger ms-1">Низкий запас</span>
                        }
                    </td>
                    <td>@m.UnitOfMeasure</td>
                    <td>@m.MinimalStock</td>
                    <td>
                        <button class="btn btn-outline-success btn-sm" onclick="openReplenish(@m.Id, '@m.Name')">Пополнить</button>
                        <button class="btn btn-outline-secondary btn-sm" onclick="openEdit(@m.Id, '@m.Name', @m.Quantity, '@m.UnitOfMeasure', @m.MinimalStock)">Изменить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Добавить -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Добавить материал</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label">Название <span class="text-danger">*</span></label><input type="text" id="addName" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label">Количество <span class="text-danger">*</span></label><input type="number" id="addQty" class="form-control" step="0.01" min="0" value="0" required /></div>
                <div class="mb-3">
                    <label class="form-label">Единица измерения <span class="text-danger">*</span></label>
                    <select id="addUnit" class="form-select" required>
                        <option value="">— Выберите —</option>
                        <optgroup label="Вес">
                            <option value="кг">кг (килограмм)</option>
                            <option value="г">г (грамм)</option>
                            <option value="т">т (тонна)</option>
                        </optgroup>
                        <optgroup label="Количество">
                            <option value="шт">шт (штука)</option>
                            <option value="упак">упак (упаковка)</option>
                        </optgroup>
                        <optgroup label="Объём">
                            <option value="л">л (литр)</option>
                            <option value="мл">мл (миллилитр)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="mb-3"><label class="form-label">Минимальный запас <span class="text-danger">*</span></label><input type="number" id="addMin" class="form-control" step="0.01" min="0" value="0" required /></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-primary" onclick="addMaterial()">Добавить</button>
            </div>
        </div>
    </div>
</div>

<!-- Пополнить -->
<div class="modal fade" id="replenishModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Пополнить: <span id="replenishName"></span></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="replenishId" />
                <label class="form-label">Добавить количество <span class="text-danger">*</span></label>
                <input type="number" id="replenishAmount" class="form-control" step="0.01" min="0.01" value="10" required />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-success" onclick="replenish()">Пополнить</button>
            </div>
        </div>
    </div>
</div>

<!-- Изменить -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Изменить материал</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="editId" />
                <div class="mb-3"><label class="form-label">Название <span class="text-danger">*</span></label><input type="text" id="editName" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label">Текущее количество <span class="text-danger">*</span></label><input type="number" id="editQty" class="form-control" step="0.01" min="0" required /></div>
                <div class="mb-3">
                    <label class="form-label">Единица измерения <span class="text-danger">*</span></label>
                    <select id="editUnit" class="form-select" required>
                        <option value="">— Выберите —</option>
                        <optgroup label="Вес">
                            <option value="кг">кг (килограмм)</option>
                            <option value="г">г (грамм)</option>
                            <option value="т">т (тонна)</option>
                        </optgroup>
                        <optgroup label="Количество">
                            <option value="шт">шт (штука)</option>
                            <option value="упак">упак (упаковка)</option>
                        </optgroup>
                        <optgroup label="Объём">
                            <option value="л">л (литр)</option>
                            <option value="мл">мл (миллилитр)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="mb-3"><label class="form-label">Минимальный запас <span class="text-danger">*</span></label><input type="number" id="editMin" class="form-control" step="0.01" min="0" required /></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-primary" onclick="saveMaterial()">Сохранить</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openReplenish(id, name) {
        document.getElementById("replenishId").value = id;
        document.getElementById("replenishName").innerText = name;
        document.getElementById("replenishAmount").value = 10;
        new bootstrap.Modal(document.getElementById("replenishModal")).show();
    }

    async function replenish() {
        const id = document.getElementById("replenishId").value;
        const amount = parseFloat(document.getElementById("replenishAmount").value);
        if (!amount || amount <= 0) { alert("Укажите положительное количество для пополнения"); return; }
        const res = await fetch(`/api/materials/${id}/stock`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ amount })
        });
        if (res.ok) location.reload();
        else { const err = await res.text(); alert("Ошибка: " + err); }
    }

    async function addMaterial() {
        const name = document.getElementById("addName").value.trim();
        const unit = document.getElementById("addUnit").value.trim();
        const qty = parseFloat(document.getElementById("addQty").value.replace(',', '.'));
        const min = parseFloat(document.getElementById("addMin").value.replace(',', '.'));
        if (!name) { alert("Введите название"); return; }
        if (!unit) { alert("Выберите единицу измерения"); return; }
        if (isNaN(qty)) { alert("Введите корректное количество "); return; }
        if (isNaN(min)) { alert("Введите корректный минимальный запас"); return; }
        if (qty < 0) { alert("Количество не может быть отрицательным"); return; }
        const res = await fetch("/api/materials", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, quantity: qty, unit, min_stock: min })
        });
        if (res.ok) location.reload();
        else { const err = await res.text(); alert("Ошибка: " + err); }
    }

    function openEdit(id, name, qty, unit, min) {
        document.getElementById("editId").value = id;
        document.getElementById("editName").value = name;
        document.getElementById("editQty").value = qty;
        document.getElementById("editUnit").value = unit; // выставляет нужный option по value
        document.getElementById("editMin").value = min;
        new bootstrap.Modal(document.getElementById("editModal")).show();
    }

    async function saveMaterial() {
        const id = document.getElementById("editId").value;
        const name = document.getElementById("editName").value.trim();
        const qty = parseFloat(document.getElementById("editQty").value.replace(',', '.'));
        const unit = document.getElementById("editUnit").value.trim();
        const min = parseFloat(document.getElementById("editMin").value.replace(',', '.'));
        if (!name) { alert("Введите название"); return; }
        if (!unit) { alert("Выберите единицу измерения"); return; }
        if (isNaN(qty)) { alert("Введите корректное количество "); return; }
        if (isNaN(min)) { alert("Введите корректный минимальный запас"); return; }
        if (qty < 0) { alert("Количество не может быть отрицательным"); return; }
        const res = await fetch(`/api/materials/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, quantity: qty, unit, min_stock: min })
        });
        if (res.ok) location.reload();
        else { const err = await res.text(); alert("Ошибка: " + err); }
    }
</script>
}
