@model IEnumerable<KR4.Models.City>
@{
    ViewData["Title"] = "Города";
}

<h2 class="mb-4">Города России</h2>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="search" class="form-control" placeholder="Поиск по названию..." value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit">Найти</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Сбросить</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">Города не найдены.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var city in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(city.PhotoUrl))
                    {
                        <img src="@city.PhotoUrl" class="card-img-top" alt="@city.Name" style="height: 200px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@city.Name</h5>
                        <p class="card-text text-muted mb-1">
                            <strong>Регион:</strong> @city.Region
                        </p>
                        <p class="card-text text-muted">
                            <strong>Население:</strong> @city.Population.ToString("N0") чел.
                        </p>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@city.Id" class="btn btn-primary btn-sm">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
